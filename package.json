{
  "name": "personal-website",
  "private": true,
  "description": "My personal website",
  "version": "0.1.0",
  "author": "Nico Chatzigianis <nico@htz.dev>",
  "bugs": {
    "url": "https://github.com/nicochatzi/website/issues"
  },
  "homepage": "https://nicochatzi.github.io/website",
  "license": "0BSD",
  "main": "n/a",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicochatzi/website.git"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "gatsby build",
    "develop": "gatsby develop",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "start": "npm run develop",
    "deploy": "gh-pages -d public",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged --allow-empty"
    }
  },
  "lint-staged": {
    "*.{ts*,js*}": "npm run format"
  },
  "dependencies": {
    "@mdx-js/mdx": "^1.6.22",
    "@mdx-js/react": "^1.6.22",
    "gatsby": "^4.5.3",
    "gatsby-plugin-feed": "^4.5.0",
    "gatsby-plugin-gatsby-cloud": "^4.5.2",
    "gatsby-plugin-google-analytics": "^4.5.0",
    "gatsby-plugin-image": "^2.5.2",
    "gatsby-plugin-manifest": "^4.5.2",
    "gatsby-plugin-mdx": "^3.5.2",
    "gatsby-plugin-offline": "^5.5.2",
    "gatsby-plugin-react-helmet": "^5.5.0",
    "gatsby-plugin-sharp": "^4.5.2",
    "gatsby-plugin-sitemap": "^5.5.0",
    "gatsby-plugin-styled-components": "^5.5.0",
    "gatsby-remark-autolink-headers": "^5.5.0",
    "gatsby-remark-copy-linked-files": "^5.5.0",
    "gatsby-remark-images": "^6.5.2",
    "gatsby-remark-responsive-iframe": "^5.5.0",
    "gatsby-remark-smartypants": "^5.5.0",
    "gatsby-source-filesystem": "^4.5.2",
    "gatsby-transformer-remark": "^5.5.2",
    "gatsby-transformer-sharp": "^4.5.0",
    "prism-react-renderer": "^1.2.1",
    "prismjs": "^1.26.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-helmet": "^6.1.0",
    "react-icons": "^4.3.1",
    "styled-components": "^5.3.3",
    "typeface-alata": "^1.1.13",
    "typeface-hanuman": "^1.1.13",
    "typeface-jetbrains-mono": "^2.0.1",
    "typeface-merriweather": "0.0.72",
    "typeface-overpass": "^1.1.13",
    "typeface-roboto": "1.1.13",
    "typeface-suwannaphum": "^1.1.13",
    "typeface-yrsa": "^1.1.13"
  },
  "devDependencies": {
    "gatsby-plugin-ts": "^3.1.0",
    "gh-pages": "^3.2.3",
    "husky": "^7.0.4",
    "lint-staged": "^12.2.0",
    "prettier": "2.2.1",
    "typescript": "^4.5.4"
  }
}
